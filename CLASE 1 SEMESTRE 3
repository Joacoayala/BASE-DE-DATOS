 FORMA DE CREAR USUARIO DE MANERA MANUAL

--COMANDO PARA PERMITIR AL USUARIO SYS EJECUTAR CODIGO
ALTER SESSION SET "_ORACLE_SCRIPT"=TRUE;

--PROCESO DE CREACION DE NUEVO USUARIO
CREATE USER JOACO
IDENTIFIED BY JOACO
DEFAULT TABLESPACE USERS
TEMPORARY TABLESPACE TEMP;

--ESPECIFICAR CUANTO ESPACIO PUEDE USAR JOACO DE LA CARPETA USERS
ALTER USER JOACO QUOTA UNLIMITED ON USERS;

--PERMISO DE CONECTARSE A UNA BASE DE DATOS
GRANT CREATE SESSION TO JOACO;

--PERMISOS DE CRUD DE TABLAS Y DATOS 
GRANT "RESOURCE" TO JOACO;
