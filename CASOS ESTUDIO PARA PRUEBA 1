CASO 02 --ESTE SI ENTRA 100%
Se necesita una consulta SQL que liste a todos los guardias activos, mostrando su código, nombre completo, edad actual, años de servicio en la empresa,
fecha estimada de jubilación (calculada a los 65 años de edad) y el recinto al cual están asignados.

Condiciones Específicas:
•	Se requiere mostrar los siguientes datos según la imagen de más abajo.
•	La fecha de jubilación debe calcularse a los 65 años de cada guardia.
•	La edad y los años de servicio deben mostrarse en números enteros.
•	El listado debe estar ordenado por la edad del guardia de forma descendente, para priorizar a aquellos guardias que se jubilarán primero

SELECT 
    -- CÓDIGO DEL GUARDIA
    G.ID_GUARDIA AS "CÓDIGO",
    
    -- NOMBRE Y APELLIDO CONCATENADOS
    G.PNOMBRE_GUARDIA || ' ' || G.APPATERNO_GUARDIA AS "NOMBRE COMPLETO",
    
    -- EDAD ACTUAL EN NÚMEROS ENTEROS
    TRUNC(MONTHS_BETWEEN(SYSDATE, G.FECHA_NAC_GUARDIA) / 12) AS "EDAD ACTUAL",
    
    -- AÑOS DE SERVICIO EN LA EMPRESA
    TRUNC(MONTHS_BETWEEN(SYSDATE, G.FECHA_CONTRATO_GUARDIA) / 12) AS "AÑOS SERVICIO",
    
    -- FECHA DE JUBILACIÓN ESTIMADA (SUMANDO 65 AÑOS)
    ADD_MONTHS(G.FECHA_NAC_GUARDIA, 65 * 12) AS "FECHA JUBILACIÓN",
    
    -- NOMBRE DEL RECINTO ASIGNADO (USANDO EL JOIN)
    R.NOMBRE_RECINTO AS "RECINTO"

-- ORIGEN DE DATOS Y UNIÓN DE TABLAS
FROM GUARDIA G
JOIN RECINTO R ON (G.ID_RECINTO = R.ID_RECINTO)

-- ORDENAMOS POR EDAD DESCENDENTE (LOS MÁS CERCANOS A JUBILARSE PRIMERO)
ORDER BY "EDAD ACTUAL" DESC;
