CASO 01 --NO SE SABE SI ENTRA EN LA PRUEBA ESTE CASO
Requerimiento:
Desarrolle una consulta SQL que agrupe a los guardias según los siguientes rangos de edad:
•	Menos de 20 años
•	Entre 21 y 30 años
•	Entre 31 y 40 años
•	Entre 41 y 50 años
•	51 años o más 
Los resultados deben mostrarse ordenados ascendentemente por el rango de edad
--------------------------------------------------------------------------------------
SELECT 
    -- Iniciamos el CASE para crear etiquetas de texto basadas en una condición
    CASE 
        -- TRUNC corta los decimales. MONTHS_BETWEEN saca meses entre hoy (SYSDATE) y el nacimiento.
        -- Dividimos por 12 para convertir esos meses en años.
        WHEN TRUNC(MONTHS_BETWEEN(SYSDATE, FECHA_NAC_GUARDIA)/12) <= 20 THEN 'HASTA 20 AÑOS'
        
        -- BETWEEN incluye los límites (21 y 30)
        WHEN TRUNC(MONTHS_BETWEEN(SYSDATE, FECHA_NAC_GUARDIA)/12) BETWEEN 21 AND 30 THEN '21 A 30 AÑOS'
        
        WHEN TRUNC(MONTHS_BETWEEN(SYSDATE, FECHA_NAC_GUARDIA)/12) BETWEEN 31 AND 40 THEN '31 A 40 AÑOS'
        
        WHEN TRUNC(MONTHS_BETWEEN(SYSDATE, FECHA_NAC_GUARDIA)/12) BETWEEN 41 AND 50 THEN '41 A 50 AÑOS'
        
        -- Si no es ninguna de las anteriores, entra en esta categoría
        ELSE '51 AÑOS O MAS'
        
    -- Cerramos el CASE y le ponemos el nombre que veremos en el encabezado de la columna
    END AS "RANGO EDAD",

    -- COUNT(*) cuenta todas las filas que caen en cada grupo creado arriba
    COUNT(*) AS "TOTAL PERSONAS"

-- Definimos la tabla de donde sacamos la información
FROM GUARDIA

-- El GROUP BY es obligatorio porque usamos COUNT. 
-- Aquí le decimos a SQL: "Junta en una sola fila a todos los que tengan el mismo RANGO_EDAD"
GROUP BY 
    CASE 
        WHEN TRUNC(MONTHS_BETWEEN(SYSDATE, FECHA_NAC_GUARDIA)/12) <= 20 THEN 'HASTA 20 AÑOS'
        WHEN TRUNC(MONTHS_BETWEEN(SYSDATE, FECHA_NAC_GUARDIA)/12) BETWEEN 21 AND 30 THEN '21 A 30 AÑOS'
        WHEN TRUNC(MONTHS_BETWEEN(SYSDATE, FECHA_NAC_GUARDIA)/12) BETWEEN 31 AND 40 THEN '31 A 40 AÑOS'
        WHEN TRUNC(MONTHS_BETWEEN(SYSDATE, FECHA_NAC_GUARDIA)/12) BETWEEN 41 AND 50 THEN '41 A 50 AÑOS'
        ELSE '51 AÑOS O MAS'
    END

-- Ordenamos el resultado por la columna "RANGO_EDAD" de forma ascendente (A-Z)
ORDER BY "RANGO EDAD" ASC;

