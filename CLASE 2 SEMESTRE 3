-- CASO 01


--TABLA A TRABAJAR
SELECT * FROM ALUMNO;

--CONSULTA CASO 01
SELECT
    CARRERAID AS "IDENTIFICACION DE LA CARRERA",
    COUNT(*) AS "TOTAL ALUMNOS MATRICULADOS",
    'LE CORRESPONDEN '||TO_CHAR(COUNT(*)*&&INGRESAR_VALOR,'$999G999')||'DEL PRESUPUESTO TOTAL ASIGNADO A PUBLICIDAD' AS "MONTO POR PUBLICIDAD"
FROM
    ALUMNO
GROUP BY
    CARRERAID
ORDER BY
    COUNT(*) DESC;


--UNDEFINE SIRVE PARA RESETEAR EL VALOR Y LO VUELVA A PEDIR CON LA PANTALLA EMERGENTE    
UNDEFINE INGRESAR_VALOR;






-- CASO 02
SELECT * FROM ALUMNO;

--CONSULTA CASO 02
SELECT
    CARRERAID AS "CARRERA",
    COUNT(*) AS "TOTAL ALUMNOS"
FROM 
    ALUMNO
    
WHERE
    CARRERAID IN (340,260,150,190)

HAVING 
    COUNT(*) > 4
GROUP BY CARRERAID

ORDER BY
    CARRERAID;

-- HAVING -> SE UTILIZA PARA REALIZAR FILTROS EN LOS GRUPOS, SE PUEDE UTILIZAR CON EL "WHERE"
